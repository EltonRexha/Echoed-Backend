generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                  @id @default(uuid())
  username              String                  @unique
  email                 String                  @unique
  firstName             String                  @map("first_name")
  lastName              String                  @map("last_name")
  verified              Boolean
  password              String?
  userStatus            UserStatus              @default(active) @map("user_status")
  followers             User[]                  @relation(name: "follow")
  following             User[]                  @relation(name: "follow")
  UserInfo              UserInfo                @relation(fields: [userInfoId], references: [id])
  userInfoId            String                  @unique @map("userId")
  posts                 Post[]
  lis                   Group[]                 @relation(name: "members")
  LikedPosts            Post[]                  @relation(name: "likes")
  savedPosts            Post[]                  @relation(name: "saved")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  createdGroups         Group[]                 @relation(name: "creator")
  messages              Message[]
  refreshTokens         refreshTokens[]
  userVerificationToken userVerificationToken[]
  ProfileImage          Media?                  @relation(fields: [mediaId], references: [id])
  mediaId               String?
  googleUser            GoogleUser?
  githubUser            GithubUser?
  UserType              UserType                @default(local)
  resetPasswordToken    resetPasswordToken[]
  Role                  Roles[]                 @default([user])
  blockedBy             User[]                  @relation(name: "blocked")
  blocks                User[]                  @relation(name: "blocked")
  postComment           postComment[]
  likedComments         postComment[] @relation(name: "likedBy")
  savedComments         postComment[] @relation(name: "savedBy")

  @@index([email])
  @@index([username])
  @@map("users")
}

model GoogleUser {
  id           String   @unique @default(uuid())
  googleUserId String   @unique
  email        String   @unique
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  OAuth        Boolean  @default(true)
  UserType     UserType @default(google)

  profileUrl String?

  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String?         @unique
  refreshTokens refreshTokens[]

  @@id([googleUserId, id])
  @@index([email])
  @@map("google_users")
}

model GithubUser {
  id           String   @unique @default(uuid())
  githubUserId String   @unique
  email        String   @unique
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  OAuth        Boolean  @default(true)
  UserType     UserType @default(github)
  profileUrl   String?

  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String?         @unique
  refreshTokens refreshTokens[]

  @@id([githubUserId, id])
  @@map("github_users")
}

model UserInfo {
  id          String   @id @default(uuid())
  gender      Gender
  dateOfBirth DateTime
  country     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  User        User?

  @@map("userInformation")
}

model Post {
  id           String        @id @default(uuid())
  author       User          @relation(fields: [userId], references: [id])
  userId       String
  content      String        @db.Text
  Reposts      Post[]        @relation(name: "reposts")
  MainPost     Post?         @relation(fields: [mainPostId], references: [id], name: "reposts")
  mainPostId   String?
  likedBy      User[]        @relation(name: "likes")
  savedBy      User[]        @relation(name: "saved")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  postComments postComment[]
  postTags     postTags[]
  Media        Media[]

  @@map("posts")
}

model postTags {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("post_tags")
}

model postComment {
  id             String        @id @default(uuid())
  author         User          @relation(fields: [authorId], references: [id])
  authorId       String
  post           Post          @relation(fields: [post_id], references: [id])
  post_id        String        @map("postsId")
  content        String
  parentComment  postComment?  @relation(fields: [postCommentsId], references: [id], name: "comments", onDelete: Cascade)
  postCommentsId String?
  comments       postComment[] @relation(name: "comments")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  likedBy        User[]        @relation(name: "likedBy")
  savedBy        User[]        @relation(name: "savedBy")
  Media          Media[]

  @@map("postComments")
}

model Media {
  id             String       @id @default(uuid())
  mimeType       String       @map("mime_type")
  path           String
  byteSize       Int          @map("byte_size")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  postMedia      Post?        @relation(fields: [postMediaId], references: [id])
  postMediaId    String?
  commentMedia   postComment? @relation(fields: [commentMediaId], references: [id])
  commentMediaId String?
  User           User[]
}

model Group {
  id           String    @id @default(uuid())
  creator      User      @relation(fields: [userId], references: [id], name: "creator")
  userId       String
  name         String
  description  String
  groupMembers User[]    @relation(name: "members")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  Messages     Message[]

  @@map("Groups")
}

model Message {
  id        String        @id @default(uuid())
  content   String
  status    MessageStatus
  Sender    User          @relation(fields: [userId], references: [id])
  Group     Group         @relation(fields: [groupId], references: [id])
  userId    String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  groupId   String

  @@map("Messages")
}

model refreshTokens {
  id           String      @id @default(uuid())
  token        String      @unique
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  revoked      Boolean     @default(false)
  User         User?       @relation(fields: [userId], references: [id])
  userId       String?
  GithubUser   GithubUser? @relation(fields: [githubUserId], references: [id])
  githubUserId String?
  GoogleUser   GoogleUser? @relation(fields: [googleUserId], references: [id])
  googleUserId String?

  @@map("refresh_tokens")
}

model resetPasswordToken {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  expiresAt DateTime

  @@map("reset_password_tokens")
}

model userVerificationToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String
  expiresAt DateTime

  @@index([createdAt])
  @@index([createdAt, userId])
  @@index([expiresAt])
  @@map("user_verification_tokens")
}

enum Roles {
  moderator
  admin
  user
}

enum UserType {
  local
  github
  google
}

enum UserStatus {
  active
  banned
}

enum MessageStatus {
  active
  deleted
}

enum Gender {
  male
  female
  other
  unknown
}
